<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Minta">
<meta name="theme-color" content="#f0faf0">
<title>Minta</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --g1: #3DB86B;
  --g2: #1E8A44;
  --g3: #C5E8B0;
  --g4: #E8F5E2;
  --g5: #F0FAF0;
  --white: #FFFFFF;
  --text: #1A2E1F;
  --text2: #5A7A62;
  --text3: #9DBFA5;
  --border: #D4EDD8;
  --card: #FFFFFF;
  --bg: #F0FAF0;
  --radius: 18px;
  --shadow: 0 2px 16px rgba(61,184,107,0.10);
}
.dark {
  --white: #1A2420;
  --text: #E8F5E2;
  --text2: #8FC9A0;
  --text3: #4A7A58;
  --border: #2A3D2F;
  --card: #1E2E24;
  --bg: #141E17;
  --g4: #1A2E1F;
  --g5: #141E17;
  --shadow: 0 2px 16px rgba(0,0,0,0.3);
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  max-width: 430px;
  margin: 0 auto;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  transition: background 0.3s, color 0.3s;
}

/* NAV */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 430px;
  background: var(--white);
  border-top: 1px solid var(--border);
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 200;
  transition: background 0.3s;
}
.nav-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 10px 0 8px;
  background: none; border: none; cursor: pointer;
  font-family: 'Nunito', sans-serif;
  color: var(--text3); font-size: 10px; font-weight: 700;
  letter-spacing: 0.3px;
  transition: color 0.2s;
  gap: 3px;
}
.nav-btn.active { color: var(--g1); }
.nav-icon { font-size: 22px; line-height: 1; }

/* VIEWS */
.view { display: none; min-height: 100vh; padding-bottom: 100px; animation: fadeIn 0.25s ease; }
.view.active { display: block; }
@keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

/* HEADER */
.page-header {
  padding: max(env(safe-area-inset-top),44px) 20px 16px;
  background: var(--white);
  border-bottom: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  transition: background 0.3s;
}
.logo-wrap { display: flex; align-items: center; gap: 10px; }
.logo-leaf {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, var(--g1), var(--g2));
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  box-shadow: 0 2px 10px rgba(61,184,107,0.3);
}
.logo-text { font-size: 24px; font-weight: 900; color: var(--g2); letter-spacing: -0.5px; }
.logo-sub { font-size: 11px; color: var(--text3); margin-top: 1px; }
.header-actions { display: flex; gap: 8px; }
.icon-btn {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--g4); border: none; cursor: pointer;
  font-size: 16px; display: flex; align-items: center; justify-content: center;
  transition: transform 0.15s;
}
.icon-btn:active { transform: scale(0.9); }

/* CARDS */
.section-pad { padding: 16px 16px 0; }
.section-title {
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--text3); margin-bottom: 12px; font-weight: 700;
}

.goal-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 18px;
  border: 1.5px solid var(--border);
  margin-bottom: 12px;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  animation: slideUp 0.3s ease both;
  position: relative; overflow: hidden;
  box-shadow: var(--shadow);
}
.goal-card:active { transform: scale(0.97); }
.goal-card.done { border-color: var(--g1); }
.goal-card.done::after {
  content: '';
  position: absolute; top:0; right:0;
  width:90px; height:90px;
  background: radial-gradient(circle at top right, rgba(61,184,107,0.12), transparent 65%);
  pointer-events: none;
}
@keyframes slideUp {
  from { transform: translateY(16px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
.card-left { display: flex; align-items: center; gap: 10px; }
.card-emoji { font-size: 26px; }
.card-name { font-size: 17px; font-weight: 800; }
.card-period { font-size: 11px; color: var(--text3); margin-top: 2px; }
.card-tag {
  font-size: 10px; font-weight: 700; padding: 3px 9px;
  border-radius: 20px; background: var(--g4); color: var(--g2);
  border: 1px solid var(--g3);
}
.badge-done {
  background: var(--g1); color: white;
  border-radius: 20px; padding: 4px 10px;
  font-size: 11px; font-weight: 800; letter-spacing: 0.3px;
}

.progress-track {
  height: 10px; background: var(--g4);
  border-radius: 100px; overflow: hidden; margin-bottom: 10px;
}
.progress-fill {
  height: 100%; border-radius: 100px;
  background: linear-gradient(90deg, var(--g1), var(--g2));
  transition: width 0.8s cubic-bezier(0.34,1.56,0.64,1);
}
.progress-fill.glow { box-shadow: 0 0 10px rgba(61,184,107,0.5); }

.card-amounts { display: flex; justify-content: space-between; align-items: baseline; }
.card-current { font-size: 22px; font-weight: 900; color: var(--g2); font-variant-numeric: tabular-nums; }
.card-target { font-size: 13px; color: var(--text3); font-variant-numeric: tabular-nums; }
.card-meta { font-size: 12px; color: var(--text3); margin-top: 5px; }

/* SUMMARY ROW */
.summary-row {
  display: flex; gap: 10px; padding: 16px 16px 0;
}
.summary-card {
  flex: 1; background: var(--card); border-radius: 14px;
  padding: 14px 10px; text-align: center;
  border: 1.5px solid var(--border); box-shadow: var(--shadow);
}
.summary-val { font-size: 22px; font-weight: 900; color: var(--g2); font-variant-numeric: tabular-nums; }
.summary-lbl { font-size: 10px; color: var(--text3); margin-top: 2px; font-weight: 700; letter-spacing: 0.5px; }

/* FAB */
.fab {
  position: fixed; bottom: calc(72px + env(safe-area-inset-bottom));
  right: calc(50% - 196px);
  width: 52px; height: 52px; border-radius: 50%;
  background: linear-gradient(135deg, var(--g1), var(--g2));
  border: none; font-size: 26px; color: white;
  cursor: pointer; box-shadow: 0 4px 18px rgba(61,184,107,0.45);
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.15s; z-index: 150;
}
.fab:active { transform: scale(0.9); }

/* DETAIL */
.detail-hero {
  padding: max(env(safe-area-inset-top),44px) 20px 20px;
  background: linear-gradient(160deg, var(--g4) 0%, var(--white) 100%);
  border-bottom: 1px solid var(--border);
}
.back-btn {
  background: none; border: none; color: var(--g2);
  font-size: 15px; font-family: 'Nunito', sans-serif;
  cursor: pointer; padding: 0; display: flex; align-items: center;
  gap: 5px; margin-bottom: 16px; font-weight: 700;
}
.detail-amount {
  font-size: 50px; font-weight: 900; color: var(--g2);
  font-variant-numeric: tabular-nums; line-height: 1;
  font-family: 'DM Mono', monospace;
}
.detail-amount sup { font-size: 22px; font-weight: 600; color: var(--text3); vertical-align: super; }
.detail-sub { font-size: 14px; color: var(--text2); margin-top: 6px; }

.celeb-banner {
  background: linear-gradient(135deg, var(--g1), var(--g2));
  color: white; border-radius: 16px; padding: 16px 20px;
  margin: 16px 16px 0; text-align: center;
  animation: pop 0.5s ease both;
}
@keyframes pop {
  0% { transform:scale(0.85); opacity:0; }
  60% { transform:scale(1.03); }
  100% { transform:scale(1); opacity:1; }
}
.celeb-title { font-size: 18px; font-weight: 900; }
.celeb-sub { font-size: 13px; opacity: 0.85; margin-top: 4px; }

.entries-wrap { padding: 16px 16px 0; }
.entry-row {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--card); border-radius: 14px; padding: 14px 16px;
  border: 1px solid var(--border); margin-bottom: 10px;
  box-shadow: var(--shadow);
}
.entry-amount { font-size: 17px; font-weight: 800; color: var(--g2); font-variant-numeric: tabular-nums; }
.entry-meta { font-size: 12px; color: var(--text3); margin-top: 2px; }
.entry-tag { font-size: 10px; background: var(--g4); color: var(--g2); padding: 2px 8px; border-radius: 10px; border: 1px solid var(--g3); display: inline-block; margin-top: 3px; }
.del-btn { background: none; border: none; color: var(--text3); font-size: 20px; cursor: pointer; padding: 4px 6px; border-radius: 8px; }
.del-btn:active { background: rgba(239,71,111,0.1); color: #EF476F; }

/* FORMS */
.form-wrap {
  padding: calc(max(env(safe-area-inset-top),44px) + 10px) 20px 0;
}
.form-title { font-size: 26px; font-weight: 900; margin-bottom: 24px; }
.field { margin-bottom: 20px; }
.field-label {
  font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--text3); display: block; margin-bottom: 8px; font-weight: 700;
}
.field-input {
  background: none; border: none;
  border-bottom: 2px solid var(--border);
  color: var(--text); font-family: 'Nunito', sans-serif;
  width: 100%; padding: 8px 0; font-size: 20px; font-weight: 700;
  transition: border-color 0.2s;
}
.field-input:focus { outline: none; border-bottom-color: var(--g1); }
.field-input.xl { font-size: 38px; color: var(--g2); font-family: 'DM Mono', monospace; }
.field-input.md { font-size: 18px; font-weight: 600; }
.field-row { display: flex; gap: 14px; }
.field-row .field { flex: 1; }
.field-select {
  background: var(--card); border: 1.5px solid var(--border);
  border-radius: 12px; color: var(--text);
  font-family: 'Nunito', sans-serif; font-size: 16px; font-weight: 600;
  padding: 10px 12px; width: 100%; appearance: none; -webkit-appearance: none;
}
.field-select:focus { outline: none; border-color: var(--g1); }

.emoji-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.emoji-opt {
  background: var(--card); border: 2px solid var(--border);
  border-radius: 12px; font-size: 22px; padding: 7px 9px; cursor: pointer;
  transition: all 0.15s;
}
.emoji-opt.sel { border-color: var(--g1); background: var(--g4); }

.tag-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.tag-opt {
  background: var(--card); border: 1.5px solid var(--border);
  border-radius: 20px; font-size: 13px; font-weight: 700;
  padding: 6px 14px; cursor: pointer; color: var(--text2);
  transition: all 0.15s;
}
.tag-opt.sel { border-color: var(--g1); background: var(--g4); color: var(--g2); }

.submit-btn {
  width: 100%; padding: 18px; border: none; border-radius: 16px;
  font-family: 'Nunito', sans-serif; font-size: 17px; font-weight: 800;
  cursor: pointer; margin-top: 10px; transition: all 0.2s;
}
.submit-btn.on { background: linear-gradient(135deg, var(--g1), var(--g2)); color: white; box-shadow: 0 4px 18px rgba(61,184,107,0.35); }
.submit-btn.off { background: var(--border); color: var(--text3); cursor: default; }

.danger-btn {
  display: block; width: calc(100% - 32px); margin: 16px 16px 0;
  padding: 14px; background: none; border: 1.5px solid var(--border);
  border-radius: 14px; font-family: 'Nunito', sans-serif; font-size: 14px;
  font-weight: 700; color: var(--text3); cursor: pointer;
}
.danger-btn:active { background: rgba(239,71,111,0.08); border-color: rgba(239,71,111,0.4); color: #EF476F; }

/* REVENUES VIEW */
.rev-header {
  padding: max(env(safe-area-inset-top),44px) 20px 16px;
  background: var(--white); border-bottom: 1px solid var(--border);
  transition: background 0.3s;
}
.rev-total-card {
  background: linear-gradient(135deg, var(--g1), var(--g2));
  border-radius: var(--radius); padding: 24px 20px; margin: 16px 16px 0;
  color: white; position: relative; overflow: hidden;
}
.rev-total-card::before {
  content: ''; position: absolute; top:-30px; right:-30px;
  width:120px; height:120px; border-radius:50%;
  background: rgba(255,255,255,0.08);
}
.rev-total-lbl { font-size: 12px; font-weight: 700; opacity: 0.8; letter-spacing: 1px; text-transform: uppercase; }
.rev-total-val { font-size: 44px; font-weight: 900; font-family: 'DM Mono', monospace; line-height: 1.1; margin: 6px 0 2px; }
.rev-total-period { font-size: 13px; opacity: 0.75; }

.rev-entry {
  background: var(--card); border-radius: 14px; padding: 14px 16px;
  border: 1px solid var(--border); margin-bottom: 10px;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: var(--shadow);
}
.rev-amount { font-size: 18px; font-weight: 900; color: var(--g2); font-variant-numeric: tabular-nums; }
.rev-meta { font-size: 12px; color: var(--text3); margin-top: 2px; }

/* CHART */
.chart-wrap {
  background: var(--card); border-radius: var(--radius); padding: 18px;
  margin: 16px 16px 0; border: 1.5px solid var(--border); box-shadow: var(--shadow);
}
.chart-title { font-size: 13px; font-weight: 800; color: var(--text2); margin-bottom: 14px; }
.chart-bars { display: flex; align-items: flex-end; gap: 6px; height: 80px; }
.chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
.chart-bar {
  width: 100%; border-radius: 6px 6px 0 0;
  background: linear-gradient(180deg, var(--g1), var(--g2));
  transition: height 0.6s cubic-bezier(0.34,1.56,0.64,1);
  min-height: 3px;
}
.chart-bar.dim { background: var(--g3); }
.chart-lbl { font-size: 9px; color: var(--text3); font-weight: 700; text-align: center; }

/* BADGES VIEW */
.badges-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 12px; padding: 16px 16px 0;
}
.badge-card {
  background: var(--card); border-radius: var(--radius); padding: 18px 14px;
  border: 1.5px solid var(--border); text-align: center;
  box-shadow: var(--shadow); transition: transform 0.15s;
}
.badge-card.earned { border-color: var(--g1); background: var(--g4); }
.badge-card:active { transform: scale(0.96); }
.badge-icon { font-size: 36px; margin-bottom: 8px; }
.badge-name { font-size: 13px; font-weight: 800; color: var(--text); }
.badge-desc { font-size: 11px; color: var(--text3); margin-top: 4px; }
.badge-card.locked .badge-icon { filter: grayscale(1); opacity: 0.35; }
.badge-card.locked .badge-name { color: var(--text3); }

/* SETTINGS */
.settings-wrap { padding: 16px 16px 0; }
.settings-section { margin-bottom: 20px; }
.setting-row {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--card); border-radius: 14px; padding: 16px;
  border: 1px solid var(--border); margin-bottom: 8px;
  box-shadow: var(--shadow);
}
.setting-label { font-size: 15px; font-weight: 700; }
.setting-sub { font-size: 12px; color: var(--text3); margin-top: 2px; }
.toggle {
  width: 48px; height: 28px; border-radius: 14px;
  background: var(--border); border: none; cursor: pointer;
  position: relative; transition: background 0.3s; flex-shrink: 0;
}
.toggle.on { background: var(--g1); }
.toggle::after {
  content: ''; position: absolute; top: 3px; left: 3px;
  width: 22px; height: 22px; border-radius: 50%;
  background: white; transition: transform 0.3s;
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
}
.toggle.on::after { transform: translateX(20px); }

.lang-opts { display: flex; gap: 8px; }
.lang-btn {
  flex: 1; padding: 10px; border-radius: 12px;
  background: var(--card); border: 1.5px solid var(--border);
  font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 700;
  color: var(--text2); cursor: pointer; transition: all 0.15s;
}
.lang-btn.sel { border-color: var(--g1); background: var(--g4); color: var(--g2); }

/* INSTALL HINT */
.install-hint {
  margin: 12px 16px 0; background: var(--white);
  border: 1.5px dashed var(--g3); border-radius: 16px;
  padding: 12px 14px; display: flex; gap: 10px; align-items: center;
  font-size: 12px; color: var(--text2); font-weight: 600;
}
.hint-close { margin-left: auto; background: none; border: none; font-size: 18px; color: var(--text3); cursor: pointer; flex-shrink: 0; }

/* MONTH COMPARE */
.compare-row {
  display: flex; gap: 10px; padding: 0 16px; margin-top: 12px;
}
.compare-card {
  flex: 1; background: var(--card); border-radius: 14px; padding: 14px;
  border: 1.5px solid var(--border); box-shadow: var(--shadow);
}
.compare-period { font-size: 10px; color: var(--text3); font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
.compare-val { font-size: 22px; font-weight: 900; color: var(--g2); font-variant-numeric: tabular-nums; margin-top: 4px; }
.compare-delta { font-size: 12px; font-weight: 700; margin-top: 3px; }
.delta-up { color: var(--g1); }
.delta-down { color: #EF476F; }

/* CONFETTI */
@keyframes confettiFall {
  to { transform: translateY(110vh) rotate(720deg); opacity: 0; }
}

/* LINK MODAL */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,0.5); z-index: 500;
  align-items: flex-end; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal-sheet {
  background: var(--white); border-radius: 24px 24px 0 0;
  padding: 20px 20px calc(20px + env(safe-area-inset-bottom));
  width: 100%; max-width: 430px;
  animation: sheetUp 0.3s ease both;
}
@keyframes sheetUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-title { font-size: 20px; font-weight: 900; margin-bottom: 16px; }
.modal-close { float: right; background: none; border: none; font-size: 22px; color: var(--text3); cursor: pointer; margin-top: -4px; }

/* EMPTY */
.empty { text-align: center; padding: 50px 24px; }
.empty-icon { font-size: 52px; margin-bottom: 14px; }
.empty-title { font-size: 18px; font-weight: 800; color: var(--text2); margin-bottom: 6px; }
.empty-sub { font-size: 14px; color: var(--text3); }

</style>
</head>
<body>

<!-- ===== HOME VIEW ===== -->
<div class="view active" id="v-home">
  <div class="page-header">
    <div class="logo-wrap">
      <div class="logo-leaf">🌿</div>
      <div>
        <div class="logo-text">Minta</div>
        <div class="logo-sub" id="logo-sub">מינטה · Objectifs</div>
      </div>
    </div>
    <div class="header-actions">
      <button class="icon-btn" onclick="toggleTheme()" title="Thème">🌙</button>
    </div>
  </div>

  <div id="install-hint" class="install-hint">
    <span>📲</span>
    <span id="hint-text">Safari → Partager ↑ → <strong>"Sur l'écran d'accueil"</strong></span>
    <button class="hint-close" onclick="dismissHint()">×</button>
  </div>

  <div id="home-summary" class="summary-row" style="display:none"></div>
  <div id="home-empty" class="empty" style="display:none">
    <div class="empty-icon">🎯</div>
    <div class="empty-title" id="empty-title">Pas encore d'objectif</div>
    <div class="empty-sub" id="empty-sub">Appuie sur + pour commencer</div>
  </div>
  <div class="section-pad">
    <div class="section-title" id="goals-section-title">Objectifs actifs</div>
    <div id="goals-list"></div>
  </div>
  <button class="fab" onclick="openAddGoal()">+</button>
</div>

<!-- ===== REVENUES VIEW ===== -->
<div class="view" id="v-revenues">
  <div class="rev-header">
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div>
        <div class="logo-text" style="font-size:20px" id="rev-title">Mes Revenus</div>
        <div class="logo-sub" id="rev-sub">Suivi de gains</div>
      </div>
      <button class="icon-btn" onclick="openAddRevenue()">+</button>
    </div>
  </div>

  <!-- Total card -->
  <div class="rev-total-card">
    <div class="rev-total-lbl" id="rev-period-lbl">Ce mois</div>
    <div class="rev-total-val" id="rev-total-val">0 ₪</div>
    <div class="rev-total-period" id="rev-total-sub">0 entrée</div>
  </div>

  <!-- Month comparison -->
  <div class="compare-row" id="compare-row"></div>

  <!-- Chart -->
  <div class="chart-wrap" id="rev-chart-wrap">
    <div class="chart-title" id="chart-title">Évolution des 6 derniers mois</div>
    <div class="chart-bars" id="chart-bars"></div>
  </div>

  <!-- Entries -->
  <div class="section-pad" style="margin-top:16px">
    <div class="section-title" id="rev-history-lbl">Historique</div>
    <div id="rev-list"></div>
  </div>
</div>

<!-- ===== BADGES VIEW ===== -->
<div class="view" id="v-badges">
  <div class="page-header">
    <div>
      <div class="logo-text" style="font-size:20px" id="badges-title">Badges</div>
      <div class="logo-sub" id="badges-sub">Tes récompenses</div>
    </div>
  </div>
  <div class="badges-grid" id="badges-grid"></div>
</div>

<!-- ===== SETTINGS VIEW ===== -->
<div class="view" id="v-settings">
  <div class="page-header">
    <div>
      <div class="logo-text" style="font-size:20px" id="settings-title">Réglages</div>
    </div>
  </div>
  <div class="settings-wrap">
    <div class="settings-section">
      <div class="section-title" id="settings-appearance">Apparence</div>
      <div class="setting-row">
        <div>
          <div class="setting-label" id="dark-mode-lbl">Mode sombre</div>
          <div class="setting-sub" id="dark-mode-sub">Thème nuit</div>
        </div>
        <button class="toggle" id="dark-toggle" onclick="toggleTheme()"></button>
      </div>
    </div>
    <div class="settings-section">
      <div class="section-title" id="settings-lang">Langue</div>
      <div class="lang-opts">
        <button class="lang-btn sel" id="lang-fr" onclick="setLang('fr')">🇫🇷 Français</button>
        <button class="lang-btn" id="lang-en" onclick="setLang('en')">🇬🇧 English</button>
        <button class="lang-btn" id="lang-he" onclick="setLang('he')">🇮🇱 עברית</button>
      </div>
    </div>
    <div class="settings-section">
      <div class="section-title">Devise par défaut</div>
      <div class="setting-row">
        <div class="setting-label">Devise</div>
        <select class="field-select" style="width:120px" id="default-currency" onchange="saveSettings()">
          <option value="₪">₪ Shekel</option>
          <option value="€">€ Euro</option>
          <option value="$">$ Dollar</option>
          <option value="£">£ Livre</option>
        </select>
      </div>
    </div>
    <div class="settings-section">
      <div class="section-title" id="settings-data">Données</div>
      <div class="setting-row" style="cursor:pointer" onclick="exportData()">
        <div>
          <div class="setting-label" id="export-lbl">Exporter</div>
          <div class="setting-sub" id="export-sub">Télécharger mes données JSON</div>
        </div>
        <span style="font-size:20px">📤</span>
      </div>
      <div class="setting-row" style="cursor:pointer" onclick="resetAll()">
        <div>
          <div class="setting-label" style="color:#EF476F" id="reset-lbl">Réinitialiser</div>
          <div class="setting-sub" id="reset-sub">Supprimer toutes les données</div>
        </div>
        <span style="font-size:20px">🗑️</span>
      </div>
    </div>
  </div>
</div>

<!-- ===== DETAIL VIEW ===== -->
<div class="view" id="v-detail">
  <div class="detail-hero" id="detail-hero">
    <button class="back-btn" onclick="showView('home')">← <span id="back-lbl">Retour</span></button>
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
      <div>
        <div id="d-emoji" style="font-size:34px;margin-bottom:4px"></div>
        <div id="d-title" style="font-size:22px;font-weight:900"></div>
        <div id="d-period" style="font-size:12px;color:var(--text3);margin-top:3px"></div>
        <div id="d-tag" style="margin-top:6px"></div>
      </div>
      <div id="d-badge"></div>
    </div>
    <div class="detail-amount"><span id="d-current"></span><sup id="d-currency"></sup></div>
    <div class="detail-sub" id="d-sub"></div>
    <div style="margin-top:16px">
      <div class="progress-track" style="height:14px">
        <div class="progress-fill" id="d-bar" style="width:0%"></div>
      </div>
      <div style="font-size:12px;color:var(--text3);margin-top:6px;text-align:right" id="d-remaining"></div>
    </div>
  </div>
  <div id="d-celeb"></div>
  <div class="entries-wrap">
    <div class="section-title" id="d-history-lbl">Historique</div>
    <div id="d-entries"></div>
  </div>
  <button class="danger-btn" id="delete-goal-btn" onclick="confirmDeleteGoal()">Supprimer cet objectif</button>
  <div style="height:16px"></div>
  <button class="fab" style="bottom:calc(72px + env(safe-area-inset-bottom))" onclick="openAddEntry()">+</button>
</div>

<!-- ===== ADD GOAL VIEW ===== -->
<div class="view" id="v-add-goal">
  <div class="form-wrap">
    <button class="back-btn" onclick="showView('home')">← <span id="ag-cancel">Annuler</span></button>
    <div class="form-title" id="ag-title">Nouvel objectif</div>
    <div class="field">
      <label class="field-label" id="ag-emoji-lbl">Icône</label>
      <div class="emoji-grid" id="ag-emoji-grid"></div>
    </div>
    <div class="field">
      <label class="field-label" id="ag-name-lbl">Nom</label>
      <input id="ag-name" type="text" class="field-input" placeholder="Wolt, Loyer..." oninput="checkGoalForm()">
    </div>
    <div class="field-row">
      <div class="field">
        <label class="field-label" id="ag-target-lbl">Objectif</label>
        <input id="ag-target" type="number" inputmode="decimal" class="field-input" placeholder="6000" oninput="checkGoalForm()">
      </div>
      <div class="field">
        <label class="field-label">Devise</label>
        <select id="ag-currency" class="field-select"></select>
      </div>
    </div>
    <div class="field">
      <label class="field-label" id="ag-period-lbl">Période</label>
      <select id="ag-period" class="field-select"></select>
    </div>
    <div class="field">
      <label class="field-label" id="ag-tag-lbl">Catégorie</label>
      <div class="tag-grid" id="ag-tag-grid"></div>
    </div>
    <button id="ag-submit" class="submit-btn off" onclick="saveGoal()">Créer</button>
  </div>
</div>

<!-- ===== ADD ENTRY VIEW ===== -->
<div class="view" id="v-add-entry">
  <div class="form-wrap">
    <button class="back-btn" onclick="showView('detail')">← <span id="ae-cancel">Annuler</span></button>
    <div id="ae-ctx" style="margin-bottom:20px"></div>
    <div class="field">
      <label class="field-label" id="ae-amount-lbl">Montant</label>
      <input id="ae-amount" type="number" inputmode="decimal" class="field-input xl" placeholder="1423" oninput="checkEntryForm()">
    </div>
    <div class="field">
      <label class="field-label" id="ae-note-lbl">Note</label>
      <input id="ae-note" type="text" class="field-input md" placeholder="Vendredi soir...">
    </div>
    <div class="field">
      <label class="field-label" id="ae-tag-lbl">Catégorie</label>
      <div class="tag-grid" id="ae-tag-grid"></div>
    </div>
    <button id="ae-submit" class="submit-btn off" onclick="addEntry()">Confirmer</button>
  </div>
</div>

<!-- ===== ADD REVENUE VIEW ===== -->
<div class="view" id="v-add-revenue">
  <div class="form-wrap">
    <button class="back-btn" onclick="showView('revenues')">← <span id="ar-cancel">Annuler</span></button>
    <div class="form-title" id="ar-title">Ajouter un revenu</div>
    <div class="field">
      <label class="field-label" id="ar-amount-lbl">Montant</label>
      <input id="ar-amount" type="number" inputmode="decimal" class="field-input xl" placeholder="2500" oninput="checkRevForm()">
    </div>
    <div class="field-row">
      <div class="field">
        <label class="field-label">Devise</label>
        <select id="ar-currency" class="field-select"></select>
      </div>
      <div class="field">
        <label class="field-label" id="ar-period-lbl">Période</label>
        <select id="ar-period" class="field-select"></select>
      </div>
    </div>
    <div class="field">
      <label class="field-label" id="ar-source-lbl">Source</label>
      <input id="ar-source" type="text" class="field-input md" placeholder="Wolt, Salaire...">
    </div>
    <div class="field">
      <label class="field-label" id="ar-note-lbl">Note</label>
      <input id="ar-note" type="text" class="field-input md" placeholder="...">
    </div>
    <div class="field">
      <label class="field-label" id="ar-tag-lbl">Catégorie</label>
      <div class="tag-grid" id="ar-tag-grid"></div>
    </div>
    <button id="ar-submit" class="submit-btn off" onclick="saveRevenue()">Confirmer</button>
  </div>
</div>

<!-- BOTTOM NAV -->
<nav class="bottom-nav">
  <button class="nav-btn active" id="nav-home" onclick="navTo('home')">
    <span class="nav-icon">🎯</span><span id="nav-lbl-home">Objectifs</span>
  </button>
  <button class="nav-btn" id="nav-revenues" onclick="navTo('revenues')">
    <span class="nav-icon">💰</span><span id="nav-lbl-rev">Revenus</span>
  </button>
  <button class="nav-btn" id="nav-badges" onclick="navTo('badges')">
    <span class="nav-icon">🏆</span><span id="nav-lbl-badges">Badges</span>
  </button>
  <button class="nav-btn" id="nav-settings" onclick="navTo('settings')">
    <span class="nav-icon">⚙️</span><span id="nav-lbl-settings">Réglages</span>
  </button>
</nav>

<script>
// ========== DATA ==========
const KEY = 'minta-v2';
let state = {
  goals: [],
  revenues: [],
  settings: { dark: false, lang: 'fr', currency: '₪' }
};
let currentGoalId = null;
let currentView = 'home';
let selEmoji = '💰';
let selTag = '';
let selRevTag = '';
let selEntryTag = '';
const celebrated = {};

const EMOJIS = ['💰','🛵','🏠','✈️','🎯','🚗','💼','🎓','💎','🏋️','📱','🎮','🌿','☕','🎸','🏖️'];
const MONTHS_FR = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const MONTHS_EN = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const MONTHS_HE = ['ינואר','פברואר','מרץ','אפריל','מאי','יוני','יולי','אוגוסט','ספטמבר','אוקטובר','נובמבר','דצמבר'];
const CURRENCIES = ['₪','€','$','£'];

const TAGS = {
  fr: ['Livraison','Salaire','Freelance','Vente','Autre'],
  en: ['Delivery','Salary','Freelance','Sale','Other'],
  he: ['משלוחים','משכורת','פרילנס','מכירה','אחר']
};

const BADGES_DEF = [
  { id:'first', icon:'🌱', name_fr:'Premier pas', name_en:'First Step', name_he:'צעד ראשון', desc_fr:'Premier objectif créé', desc_en:'First goal created', desc_he:'יעד ראשון נוצר', check: s => s.goals.length >= 1 },
  { id:'goal1', icon:'🎯', name_fr:'En cible', name_en:'On Target', name_he:'במטרה', desc_fr:'1 objectif atteint', desc_en:'1 goal reached', desc_he:'יעד 1 הושג', check: s => s.goals.filter(g=>getTotal(g)>=g.target).length >= 1 },
  { id:'goal3', icon:'🏆', name_fr:'Triple', name_en:'Triple', name_he:'טריפל', desc_fr:'3 objectifs atteints', desc_en:'3 goals reached', desc_he:'3 יעדים הושגו', check: s => s.goals.filter(g=>getTotal(g)>=g.target).length >= 3 },
  { id:'rev1k', icon:'💸', name_fr:'1000 gagnés', name_en:'1k Earned', name_he:'אלף הרוויח', desc_fr:'1000 en revenus', desc_en:'1000 in revenues', desc_he:'1000 בהכנסות', check: s => getTotalRevenues() >= 1000 },
  { id:'rev10k', icon:'🤑', name_fr:'10K Club', name_en:'10K Club', name_he:'מועדון 10K', desc_fr:'10 000 en revenus', desc_en:'10,000 in revenues', desc_he:'10,000 בהכנסות', check: s => getTotalRevenues() >= 10000 },
  { id:'streak3', icon:'🔥', name_fr:'En feu', name_en:'On Fire', name_he:'בוער', desc_fr:'3 mois consécutifs', desc_en:'3 consecutive months', desc_he:'3 חודשים רצופים', check: s => hasStreak(3) },
  { id:'consistent', icon:'📅', name_fr:'Régulier', name_en:'Consistent', name_he:'עקבי', desc_fr:'5 entrées en une semaine', desc_en:'5 entries in a week', desc_he:'5 הזנות בשבוע', check: s => hasWeeklyStreak() },
  { id:'overachiever', icon:'⭐', name_fr:'Surpassé', name_en:'Overachiever', name_he:'מצטיין', desc_fr:'Dépasser un objectif de 20%', desc_en:'Exceed a goal by 20%', desc_he:'חריגה ב-20%', check: s => s.goals.some(g=>getTotal(g) >= g.target*1.2) },
];

// ========== STORAGE ==========
function save() { localStorage.setItem(KEY, JSON.stringify(state)); }
function load() {
  try { const d = localStorage.getItem(KEY); if (d) state = JSON.parse(d); } catch {}
  if (!state.settings) state.settings = { dark:false, lang:'fr', currency:'₪' };
  if (!state.revenues) state.revenues = [];
}

// ========== INIT ==========
function init() {
  load();
  applyTheme();
  applyLang();
  buildEmojiGrid('ag-emoji-grid');
  buildPeriodSelect('ag-period');
  buildPeriodSelect('ar-period');
  buildCurrencySelect('ag-currency');
  buildCurrencySelect('ar-currency');
  buildTagGrid('ag-tag-grid', t => { selTag = t; });
  buildTagGrid('ae-tag-grid', t => { selEntryTag = t; });
  buildTagGrid('ar-tag-grid', t => { selRevTag = t; });
  renderHome();
  renderRevenues();
  renderBadges();
  if (localStorage.getItem('minta-hint')) document.getElementById('install-hint').style.display = 'none';
}

function dismissHint() {
  document.getElementById('install-hint').style.display = 'none';
  localStorage.setItem('minta-hint', '1');
}

// ========== NAVIGATION ==========
function navTo(name) {
  currentView = name;
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('v-' + name).classList.add('active');
  document.getElementById('nav-' + name).classList.add('active');
  window.scrollTo(0,0);
  if (name === 'home') renderHome();
  if (name === 'revenues') renderRevenues();
  if (name === 'badges') renderBadges();
}

function showView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('v-' + name).classList.add('active');
  window.scrollTo(0,0);
  if (name === 'home') { renderHome(); syncNav('home'); }
  if (name === 'revenues') { renderRevenues(); syncNav('revenues'); }
  if (name === 'detail') renderDetail();
}

function syncNav(name) {
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const el = document.getElementById('nav-' + name);
  if (el) el.classList.add('active');
}

// ========== THEME ==========
function toggleTheme() {
  state.settings.dark = !state.settings.dark;
  save();
  applyTheme();
}
function applyTheme() {
  document.body.classList.toggle('dark', state.settings.dark);
  const t = document.getElementById('dark-toggle');
  if (t) t.classList.toggle('on', state.settings.dark);
}

// ========== LANG ==========
const T = {
  fr: {
    sub:'מינטה · Objectifs', hint:'Safari → Partager ↑ → <strong>"Sur l\'écran d\'accueil"</strong>',
    goalsSection:'Objectifs actifs', emptyTitle:'Pas encore d\'objectif', emptySub:'Appuie sur + pour commencer',
    revTitle:'Mes Revenus', revSub:'Suivi de gains', revPeriodLbl:'Ce mois',
    chartTitle:'Évolution des 6 derniers mois', revHistoryLbl:'Historique',
    badgesTitle:'Badges', badgesSub:'Tes récompenses',
    settingsTitle:'Réglages', settingsAppearance:'Apparence', darkModeLbl:'Mode sombre', darkModeSub:'Thème nuit',
    settingsLang:'Langue', settingsData:'Données', exportLbl:'Exporter', exportSub:'Télécharger mes données JSON',
    resetLbl:'Réinitialiser', resetSub:'Supprimer toutes les données',
    agTitle:'Nouvel objectif', agEmojiLbl:'Icône', agNameLbl:'Nom', agTargetLbl:'Objectif',
    agPeriodLbl:'Période', agTagLbl:'Catégorie', agCreate:'Créer',
    aeCancel:'Annuler', aeAmountLbl:'Montant', aeNoteLbl:'Note', aeTagLbl:'Catégorie', aeConfirm:'Confirmer',
    arTitle:'Ajouter un revenu', arAmountLbl:'Montant', arPeriodLbl:'Période', arSourceLbl:'Source',
    arNoteLbl:'Note', arTagLbl:'Catégorie', arConfirm:'Confirmer',
    backLbl:'Retour', deleteGoal:'Supprimer cet objectif',
    navGoals:'Objectifs', navRev:'Revenus', navBadges:'Badges', navSettings:'Réglages',
    atteint:'ATTEINT', objectifAtteint:'Objectif atteint !', felicitations:'Félicitations !',
    restants:'restants', entrees:'entrée', entree:'entrée', sur:'sur',
    prevMonth:'Mois préc.', currMonth:'Ce mois',
  },
  en: {
    sub:'מינטה · Goals', hint:'Safari → Share ↑ → <strong>"Add to Home Screen"</strong>',
    goalsSection:'Active Goals', emptyTitle:'No goals yet', emptySub:'Tap + to get started',
    revTitle:'My Revenues', revSub:'Earnings tracker', revPeriodLbl:'This month',
    chartTitle:'Last 6 months', revHistoryLbl:'History',
    badgesTitle:'Badges', badgesSub:'Your rewards',
    settingsTitle:'Settings', settingsAppearance:'Appearance', darkModeLbl:'Dark mode', darkModeSub:'Night theme',
    settingsLang:'Language', settingsData:'Data', exportLbl:'Export', exportSub:'Download my JSON data',
    resetLbl:'Reset', resetSub:'Delete all data',
    agTitle:'New goal', agEmojiLbl:'Icon', agNameLbl:'Name', agTargetLbl:'Target',
    agPeriodLbl:'Period', agTagLbl:'Category', agCreate:'Create',
    aeCancel:'Cancel', aeAmountLbl:'Amount', aeNoteLbl:'Note', aeTagLbl:'Category', aeConfirm:'Confirm',
    arTitle:'Add revenue', arAmountLbl:'Amount', arPeriodLbl:'Period', arSourceLbl:'Source',
    arNoteLbl:'Note', arTagLbl:'Category', arConfirm:'Confirm',
    backLbl:'Back', deleteGoal:'Delete this goal',
    navGoals:'Goals', navRev:'Revenue', navBadges:'Badges', navSettings:'Settings',
    atteint:'REACHED', objectifAtteint:'Goal reached!', felicitations:'Congrats!',
    restants:'remaining', entrees:'entries', entree:'entry', sur:'of',
    prevMonth:'Prev month', currMonth:'This month',
  },
  he: {
    sub:'מינטה · יעדים', hint:'Safari → שתף ↑ → <strong>"הוסף למסך הבית"</strong>',
    goalsSection:'יעדים פעילים', emptyTitle:'אין יעדים עדיין', emptySub:'לחץ + כדי להתחיל',
    revTitle:'ההכנסות שלי', revSub:'מעקב רווחים', revPeriodLbl:'החודש',
    chartTitle:'6 חודשים אחרונים', revHistoryLbl:'היסטוריה',
    badgesTitle:'תגים', badgesSub:'הפרסים שלך',
    settingsTitle:'הגדרות', settingsAppearance:'מראה', darkModeLbl:'מצב כהה', darkModeSub:'ערכת לילה',
    settingsLang:'שפה', settingsData:'נתונים', exportLbl:'ייצוא', exportSub:'הורד נתוני JSON',
    resetLbl:'איפוס', resetSub:'מחק את כל הנתונים',
    agTitle:'יעד חדש', agEmojiLbl:'אייקון', agNameLbl:'שם', agTargetLbl:'יעד',
    agPeriodLbl:'תקופה', agTagLbl:'קטגוריה', agCreate:'צור',
    aeCancel:'ביטול', aeAmountLbl:'סכום', aeNoteLbl:'הערה', aeTagLbl:'קטגוריה', aeConfirm:'אישור',
    arTitle:'הוסף הכנסה', arAmountLbl:'סכום', arPeriodLbl:'תקופה', arSourceLbl:'מקור',
    arNoteLbl:'הערה', arTagLbl:'קטגוריה', arConfirm:'אישור',
    backLbl:'חזרה', deleteGoal:'מחק יעד זה',
    navGoals:'יעדים', navRev:'הכנסות', navBadges:'תגים', navSettings:'הגדרות',
    atteint:'הושג', objectifAtteint:'!היעד הושג', felicitations:'!כל הכבוד',
    restants:'נותרו', entrees:'הזנות', entree:'הזנה', sur:'מתוך',
    prevMonth:'חודש קודם', currMonth:'החודש',
  }
};

function t(key) { return (T[state.settings.lang] || T.fr)[key] || key; }

function setLang(lang) {
  state.settings.lang = lang;
  save();
  applyLang();
  renderHome();
  renderRevenues();
  renderBadges();
  if (currentView === 'detail') renderDetail();
}

function applyLang() {
  const lang = state.settings.lang;
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('sel'));
  const lb = document.getElementById('lang-' + lang);
  if (lb) lb.classList.add('sel');

  setText('logo-sub', t('sub'));
  setText('hint-text', t('hint'));
  setText('goals-section-title', t('goalsSection'));
  setText('empty-title', t('emptyTitle'));
  setText('empty-sub', t('emptySub'));
  setText('rev-title', t('revTitle'));
  setText('rev-sub', t('revSub'));
  setText('rev-period-lbl', t('revPeriodLbl'));
  setText('chart-title', t('chartTitle'));
  setText('rev-history-lbl', t('revHistoryLbl'));
  setText('badges-title', t('badgesTitle'));
  setText('badges-sub', t('badgesSub'));
  setText('settings-title', t('settingsTitle'));
  setText('settings-appearance', t('settingsAppearance'));
  setText('dark-mode-lbl', t('darkModeLbl'));
  setText('dark-mode-sub', t('darkModeSub'));
  setText('settings-lang', t('settingsLang'));
  setText('settings-data', t('settingsData'));
  setText('export-lbl', t('exportLbl'));
  setText('export-sub', t('exportSub'));
  setText('reset-lbl', t('resetLbl'));
  setText('reset-sub', t('resetSub'));
  setText('ag-title', t('agTitle'));
  setText('ag-emoji-lbl', t('agEmojiLbl'));
  setText('ag-name-lbl', t('agNameLbl'));
  setText('ag-target-lbl', t('agTargetLbl'));
  setText('ag-period-lbl', t('agPeriodLbl'));
  setText('ag-tag-lbl', t('agTagLbl'));
  setText('ag-submit', t('agCreate'));
  setText('ae-cancel', t('aeCancel'));
  setText('ae-amount-lbl', t('aeAmountLbl'));
  setText('ae-note-lbl', t('aeNoteLbl'));
  setText('ae-tag-lbl', t('aeTagLbl'));
  setText('ae-submit', t('aeConfirm'));
  setText('ar-title', t('arTitle'));
  setText('ar-cancel', t('aeCancel'));
  setText('ar-amount-lbl', t('arAmountLbl'));
  setText('ar-period-lbl', t('arPeriodLbl'));
  setText('ar-source-lbl', t('arSourceLbl'));
  setText('ar-note-lbl', t('arNoteLbl'));
  setText('ar-tag-lbl', t('arTagLbl'));
  setText('ar-submit', t('arConfirm'));
  setText('back-lbl', t('backLbl'));
  setText('delete-goal-btn', t('deleteGoal'));
  setText('nav-lbl-home', t('navGoals'));
  setText('nav-lbl-rev', t('navRev'));
  setText('nav-lbl-badges', t('navBadges'));
  setText('nav-lbl-settings', t('navSettings'));

  // Rebuild tag grids
  buildTagGrid('ag-tag-grid', t2 => { selTag = t2; });
  buildTagGrid('ae-tag-grid', t2 => { selEntryTag = t2; });
  buildTagGrid('ar-tag-grid', t2 => { selRevTag = t2; });

  // Rebuild period selects
  buildPeriodSelect('ag-period');
  buildPeriodSelect('ar-period');

  // RTL
  document.body.style.direction = lang === 'he' ? 'rtl' : 'ltr';
}

function setText(id, val) { const el = document.getElementById(id); if (el) el.innerHTML = val; }

// ========== HOME ==========
function renderHome() {
  const list = document.getElementById('goals-list');
  const empty = document.getElementById('home-empty');
  const summary = document.getElementById('home-summary');
  list.innerHTML = '';

  if (state.goals.length === 0) {
    empty.style.display = 'block'; summary.style.display = 'none'; return;
  }
  empty.style.display = 'none'; summary.style.display = 'flex';

  const done = state.goals.filter(g => getTotal(g) >= g.target).length;
  summary.innerHTML = `
    <div class="summary-card"><div class="summary-val">${state.goals.length}</div><div class="summary-lbl">${t('navGoals')}</div></div>
    <div class="summary-card"><div class="summary-val">${done}</div><div class="summary-lbl">${t('atteint')}</div></div>
    <div class="summary-card"><div class="summary-val">${state.goals.length - done}</div><div class="summary-lbl">En cours</div></div>
  `;

  state.goals.forEach((g, i) => {
    const total = getTotal(g);
    const pct = Math.min(100, (total / g.target) * 100);
    const isDone = pct >= 100;
    const card = document.createElement('div');
    card.className = 'goal-card' + (isDone ? ' done' : '');
    card.style.animationDelay = (i * 0.06) + 's';
    card.innerHTML = `
      <div class="card-top">
        <div class="card-left">
          <span class="card-emoji">${g.emoji}</span>
          <div>
            <div class="card-name">${g.title}</div>
            <div class="card-period">${g.period}</div>
            ${g.tag ? `<span class="card-tag">${g.tag}</span>` : ''}
          </div>
        </div>
        ${isDone ? `<div class="badge-done">✓ ${t('atteint')}</div>` : ''}
      </div>
      <div class="progress-track"><div class="progress-fill${isDone?' glow':''}" style="width:${pct}%"></div></div>
      <div class="card-amounts">
        <div class="card-current">${fmt(total)} <span style="font-size:14px;color:var(--text3);font-weight:600">${g.currency}</span></div>
        <div class="card-target">${t('sur')} ${fmt(g.target)} ${g.currency}</div>
      </div>
      <div class="card-meta">${Math.round(pct)}% · ${g.entries.length} ${g.entries.length>1?t('entrees'):t('entree')}${!isDone&&total>0?' · '+fmt(g.target-total)+' '+g.currency+' '+t('restants'):''}</div>
    `;
    card.onclick = () => { currentGoalId = g.id; showView('detail'); };
    list.appendChild(card);
  });
}

// ========== DETAIL ==========
function renderDetail() {
  const g = state.goals.find(x => x.id === currentGoalId);
  if (!g) return;
  const total = getTotal(g);
  const pct = Math.min(100, (total / g.target) * 100);
  const isDone = pct >= 100;

  document.getElementById('d-emoji').textContent = g.emoji;
  document.getElementById('d-title').textContent = g.title;
  document.getElementById('d-period').textContent = g.period;
  document.getElementById('d-tag').innerHTML = g.tag ? `<span class="card-tag">${g.tag}</span>` : '';
  document.getElementById('d-badge').innerHTML = isDone ? `<div class="badge-done">🎉 ${t('atteint')}</div>` : '';
  document.getElementById('d-current').textContent = fmt(total);
  document.getElementById('d-currency').textContent = ' ' + g.currency;
  document.getElementById('d-sub').textContent = `${t('sur')} ${fmt(g.target)} ${g.currency} · ${Math.round(pct)}%`;
  document.getElementById('d-remaining').textContent = isDone
    ? `✓ ${t('objectifAtteint')}`
    : `${fmt(g.target - total)} ${g.currency} ${t('restants')}`;

  setTimeout(() => {
    const bar = document.getElementById('d-bar');
    if (bar) { bar.style.width = pct + '%'; bar.className = 'progress-fill' + (isDone?' glow':''); }
  }, 50);

  const celeb = document.getElementById('d-celeb');
  if (isDone && !celebrated[g.id]) {
    celebrated[g.id] = true;
    launchConfetti();
    celeb.innerHTML = `<div class="celeb-banner"><div class="celeb-title">🎉 ${t('objectifAtteint')}</div><div class="celeb-sub">${t('felicitations')}</div></div>`;
  } else if (!isDone) { celeb.innerHTML = ''; }

  const list = document.getElementById('d-entries');
  list.innerHTML = '';
  if (g.entries.length === 0) {
    list.innerHTML = `<div class="empty" style="padding:30px 0"><div class="empty-sub">${t('emptySub')}</div></div>`;
  } else {
    [...g.entries].reverse().forEach(e => {
      const el = document.createElement('div');
      el.className = 'entry-row';
      el.innerHTML = `
        <div>
          <div class="entry-amount">+${fmt(e.amount)} ${g.currency}</div>
          <div class="entry-meta">${e.date}${e.note?' · '+e.note:''}</div>
          ${e.tag ? `<span class="entry-tag">${e.tag}</span>` : ''}
        </div>
        <button class="del-btn" onclick="deleteEntry(${e.id})">×</button>
      `;
      list.appendChild(el);
    });
  }
}

// ========== REVENUES ==========
function renderRevenues() {
  const now = new Date();
  const curMonth = getMonthKey(now);
  const curEntries = state.revenues.filter(r => r.period === curMonth || r.periodLabel === getPeriodLabel(now));
  const curTotal = curEntries.reduce((s,r) => s+r.amount, 0);

  document.getElementById('rev-total-val').textContent = `${fmt(curTotal)} ${state.settings.currency}`;
  document.getElementById('rev-total-sub').textContent = `${curEntries.length} ${curEntries.length>1?t('entrees'):t('entree')}`;

  // Month comparison
  const prevDate = new Date(now.getFullYear(), now.getMonth()-1, 1);
  const prevMonth = getMonthKey(prevDate);
  const prevEntries = state.revenues.filter(r => r.period === prevMonth);
  const prevTotal = prevEntries.reduce((s,r) => s+r.amount, 0);
  const delta = curTotal - prevTotal;
  const deltaHtml = prevTotal > 0
    ? `<div class="compare-delta ${delta>=0?'delta-up':'delta-down'}">${delta>=0?'↑':'↓'} ${fmt(Math.abs(delta))} ${state.settings.currency}</div>`
    : '';
  document.getElementById('compare-row').innerHTML = `
    <div class="compare-card">
      <div class="compare-period">${t('prevMonth')}</div>
      <div class="compare-val">${fmt(prevTotal)} ${state.settings.currency}</div>
      <div class="compare-delta" style="color:var(--text3)">${prevEntries.length} ${t('entrees')}</div>
    </div>
    <div class="compare-card">
      <div class="compare-period">${t('currMonth')}</div>
      <div class="compare-val">${fmt(curTotal)} ${state.settings.currency}</div>
      ${deltaHtml}
    </div>
  `;

  // Chart - last 6 months
  const months = [];
  for (let i=5;i>=0;i--) {
    const d = new Date(now.getFullYear(), now.getMonth()-i, 1);
    months.push({ key: getMonthKey(d), label: getShortMonth(d) });
  }
  const totals = months.map(m => state.revenues.filter(r=>r.period===m.key).reduce((s,r)=>s+r.amount,0));
  const maxVal = Math.max(...totals, 1);
  const barsEl = document.getElementById('chart-bars');
  barsEl.innerHTML = '';
  months.forEach((m,i) => {
    const pct = (totals[i]/maxVal)*100;
    const isCur = i === 5;
    barsEl.innerHTML += `
      <div class="chart-bar-wrap">
        <div class="chart-bar${isCur?'':' dim'}" style="height:${Math.max(pct,3)}%"></div>
        <div class="chart-lbl">${m.label}</div>
      </div>`;
  });

  // List
  const list = document.getElementById('rev-list');
  list.innerHTML = '';
  if (state.revenues.length === 0) {
    list.innerHTML = `<div class="empty"><div class="empty-icon">💰</div><div class="empty-title">${t('emptyTitle')}</div><div class="empty-sub">${t('emptySub')}</div></div>`;
    return;
  }
  [...state.revenues].reverse().forEach(r => {
    const el = document.createElement('div');
    el.className = 'rev-entry';
    el.innerHTML = `
      <div>
        <div class="rev-amount">+${fmt(r.amount)} ${r.currency}</div>
        <div class="rev-meta">${r.periodLabel}${r.source?' · '+r.source:''}${r.note?' · '+r.note:''}</div>
        ${r.tag ? `<span class="entry-tag">${r.tag}</span>` : ''}
      </div>
      <button class="del-btn" onclick="deleteRevenue(${r.id})">×</button>
    `;
    list.appendChild(el);
  });
}

// ========== BADGES ==========
function renderBadges() {
  const grid = document.getElementById('badges-grid');
  grid.innerHTML = '';
  const lang = state.settings.lang;
  BADGES_DEF.forEach(b => {
    const earned = b.check(state);
    const card = document.createElement('div');
    card.className = 'badge-card ' + (earned ? 'earned' : 'locked');
    card.innerHTML = `
      <div class="badge-icon">${b.icon}</div>
      <div class="badge-name">${b['name_'+lang] || b.name_fr}</div>
      <div class="badge-desc">${b['desc_'+lang] || b.desc_fr}</div>
    `;
    grid.appendChild(card);
  });
}

// ========== ADD GOAL ==========
function openAddGoal() {
  selEmoji = '💰'; selTag = '';
  document.getElementById('ag-name').value = '';
  document.getElementById('ag-target').value = '';
  document.getElementById('ag-submit').className = 'submit-btn off';
  document.querySelectorAll('#ag-emoji-grid .emoji-opt').forEach((b,i) => b.classList.toggle('sel', EMOJIS[i]==='💰'));
  document.querySelectorAll('#ag-tag-grid .tag-opt').forEach(b => b.classList.remove('sel'));
  showView('add-goal'); syncNav('');
}

function buildEmojiGrid(containerId) {
  const grid = document.getElementById(containerId);
  if (!grid) return;
  grid.innerHTML = '';
  EMOJIS.forEach(e => {
    const btn = document.createElement('button');
    btn.className = 'emoji-opt' + (e===selEmoji?' sel':'');
    btn.textContent = e;
    btn.onclick = () => {
      selEmoji = e;
      document.querySelectorAll('#'+containerId+' .emoji-opt').forEach(b => b.classList.remove('sel'));
      btn.classList.add('sel');
    };
    grid.appendChild(btn);
  });
}

function buildTagGrid(containerId, onSelect) {
  const grid = document.getElementById(containerId);
  if (!grid) return;
  grid.innerHTML = '';
  const tags = TAGS[state.settings.lang] || TAGS.fr;
  tags.forEach(tag => {
    const btn = document.createElement('button');
    btn.className = 'tag-opt';
    btn.textContent = tag;
    btn.onclick = () => {
      document.querySelectorAll('#'+containerId+' .tag-opt').forEach(b => b.classList.remove('sel'));
      btn.classList.add('sel');
      onSelect(tag);
    };
    grid.appendChild(btn);
  });
}

function buildPeriodSelect(id) {
  const sel = document.getElementById(id);
  if (!sel) return;
  sel.innerHTML = '';
  const now = new Date();
  const months = state.settings.lang==='en' ? MONTHS_EN : state.settings.lang==='he' ? MONTHS_HE : MONTHS_FR;
  for (let i=0;i<12;i++) {
    const d = new Date(now.getFullYear(), now.getMonth()+i);
    const label = months[d.getMonth()] + ' ' + d.getFullYear();
    sel.innerHTML += `<option value="${getMonthKey(d)}">${label}</option>`;
  }
}

function buildCurrencySelect(id) {
  const sel = document.getElementById(id);
  if (!sel) return;
  sel.innerHTML = '';
  CURRENCIES.forEach(c => { sel.innerHTML += `<option value="${c}" ${c===state.settings.currency?'selected':''}>${c}</option>`; });
}

function checkGoalForm() {
  const ok = document.getElementById('ag-name').value && document.getElementById('ag-target').value;
  document.getElementById('ag-submit').className = 'submit-btn ' + (ok?'on':'off');
}

function saveGoal() {
  const title = document.getElementById('ag-name').value.trim();
  const target = parseFloat(document.getElementById('ag-target').value);
  if (!title || !target) return;
  const periodKey = document.getElementById('ag-period').value;
  const periodLabel = document.getElementById('ag-period').options[document.getElementById('ag-period').selectedIndex].text;
  state.goals.push({
    id: Date.now(), title, target, emoji: selEmoji,
    currency: document.getElementById('ag-currency').value,
    period: periodLabel, periodKey, tag: selTag, entries: []
  });
  save(); renderHome(); renderBadges();
  showView('home');
}

// ========== ADD ENTRY ==========
function openAddEntry() {
  const g = state.goals.find(x=>x.id===currentGoalId);
  if (!g) return;
  selEntryTag = '';
  document.getElementById('ae-amount').value = '';
  document.getElementById('ae-note').value = '';
  document.getElementById('ae-submit').className = 'submit-btn off';
  document.querySelectorAll('#ae-tag-grid .tag-opt').forEach(b=>b.classList.remove('sel'));
  document.getElementById('ae-ctx').innerHTML = `
    <div style="font-size:28px;margin-bottom:4px">${g.emoji}</div>
    <div style="font-size:20px;font-weight:900">${g.title}</div>
    <div style="font-size:12px;color:var(--text3);margin-top:2px">${g.period}</div>
  `;
  showView('add-entry');
}

function checkEntryForm() {
  const ok = document.getElementById('ae-amount').value;
  document.getElementById('ae-submit').className = 'submit-btn ' + (ok?'on':'off');
}

function addEntry() {
  const amount = parseFloat(document.getElementById('ae-amount').value);
  if (!amount) return;
  const g = state.goals.find(x=>x.id===currentGoalId);
  if (!g) return;
  g.entries.push({ id:Date.now(), amount, note:document.getElementById('ae-note').value.trim(), tag:selEntryTag, date:new Date().toLocaleDateString('fr-FR') });
  save(); renderBadges(); showView('detail');
}

function deleteEntry(entryId) {
  const g = state.goals.find(x=>x.id===currentGoalId);
  if (!g) return;
  g.entries = g.entries.filter(e=>e.id!==entryId);
  save(); renderDetail();
}

function confirmDeleteGoal() {
  if (confirm(t('deleteGoal') + ' ?')) {
    state.goals = state.goals.filter(g=>g.id!==currentGoalId);
    save(); showView('home');
  }
}

// ========== REVENUES ==========
function openAddRevenue() {
  selRevTag = '';
  document.getElementById('ar-amount').value = '';
  document.getElementById('ar-source').value = '';
  document.getElementById('ar-note').value = '';
  document.getElementById('ar-submit').className = 'submit-btn off';
  document.querySelectorAll('#ar-tag-grid .tag-opt').forEach(b=>b.classList.remove('sel'));
  buildCurrencySelect('ar-currency');
  showView('add-revenue');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
}

function checkRevForm() {
  const ok = document.getElementById('ar-amount').value;
  document.getElementById('ar-submit').className = 'submit-btn ' + (ok?'on':'off');
}

function saveRevenue() {
  const amount = parseFloat(document.getElementById('ar-amount').value);
  if (!amount) return;
  const periodSel = document.getElementById('ar-period');
  const periodKey = periodSel.value;
  const periodLabel = periodSel.options[periodSel.selectedIndex].text;
  state.revenues.push({
    id: Date.now(), amount,
    currency: document.getElementById('ar-currency').value,
    period: periodKey, periodLabel,
    source: document.getElementById('ar-source').value.trim(),
    note: document.getElementById('ar-note').value.trim(),
    tag: selRevTag
  });
  save(); renderRevenues(); renderBadges();
  navTo('revenues');
}

function deleteRevenue(id) {
  state.revenues = state.revenues.filter(r=>r.id!==id);
  save(); renderRevenues();
}

// ========== SETTINGS ==========
function saveSettings() {
  state.settings.currency = document.getElementById('default-currency').value;
  save();
}

function exportData() {
  const blob = new Blob([JSON.stringify(state, null, 2)], {type:'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'minta-data.json';
  document.body.appendChild(a); a.click();
  document.body.removeChild(a);
}

function resetAll() {
  if (confirm(t('resetLbl') + ' ?')) {
    state = { goals:[], revenues:[], settings: state.settings };
    save(); renderHome(); renderRevenues(); renderBadges();
  }
}

// ========== HELPERS ==========
function getTotal(g) { return g.entries.reduce((s,e)=>s+e.amount,0); }
function getTotalRevenues() { return state.revenues.reduce((s,r)=>s+r.amount,0); }
function fmt(n) { return Number(n).toLocaleString('fr-FR'); }

function getMonthKey(d) { return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`; }
function getPeriodLabel(d) {
  const months = state.settings.lang==='en'?MONTHS_EN:state.settings.lang==='he'?MONTHS_HE:MONTHS_FR;
  return months[d.getMonth()] + ' ' + d.getFullYear();
}
function getShortMonth(d) {
  const months = state.settings.lang==='en'?MONTHS_EN:state.settings.lang==='he'?MONTHS_HE:MONTHS_FR;
  return months[d.getMonth()].slice(0,3);
}

function hasStreak(n) {
  const now = new Date();
  for (let i=0;i<n;i++) {
    const d = new Date(now.getFullYear(), now.getMonth()-i, 1);
    const key = getMonthKey(d);
    if (!state.revenues.some(r=>r.period===key)) return false;
  }
  return true;
}
function hasWeeklyStreak() {
  const week = 7*24*60*60*1000;
  const now = Date.now();
  const recent = [...state.goals.flatMap(g=>g.entries), ...state.revenues].filter(e=>now-e.id<week);
  return recent.length >= 5;
}

// ========== CONFETTI ==========
function launchConfetti() {
  const colors = ['#3DB86B','#1E8A44','#C5E8B0','#FFD166','#06D6A0','#ffffff'];
  for (let i=0;i<60;i++) {
    const el = document.createElement('div');
    const size = 6+Math.random()*8;
    el.style.cssText = `position:fixed;width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:${Math.random()>.5?'50%':'3px'};left:${Math.random()*100}vw;top:-20px;z-index:9999;pointer-events:none;animation:confettiFall ${1.5+Math.random()*2}s ease-in ${Math.random()*.5}s forwards;`;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(), 3500);
  }
}

init();
</script>
</body>
</html>
